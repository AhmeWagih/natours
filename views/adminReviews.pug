extends base

block content
  main.main
    .user-view
      nav.user-view__menu
        ul.side-nav
          li.side-nav--active
            a(href='/account')
              svg
                use(xlink:href='img/icons.svg#icon-settings')
              | Back
          li.side-nav--active
            a(href='/admin/tours')
              svg
                use(xlink:href='img/icons.svg#icon-map')
              | Manage Tours
          li.side-nav--active
            a(href='/admin/users')
              svg
                use(xlink:href='img/icons.svg#icon-users')
              | Manage Users
          li.side-nav--active
            a(href='/admin/bookings')
              svg
                use(xlink:href='img/icons.svg#icon-booking')
              | Manage Bookings
          li.side-nav--active
            a(href='/admin/reviews')
              svg
                use(xlink:href='img/icons.svg#icon-review')
              | Manage Reviews

      .user-view__content
        .admin-view__form-container
          h2.heading-secondary.ma-bt-md Manage all reviews
          
          .admin-table
            table
              thead
                tr
                  th Tour
                  th User
                  th Rating
                  th Review
                  th Date
                  th Actions
              tbody
                each review in reviews
                  tr
                    td= review.tour ? review.tour.name : 'N/A'
                    td= review.user ? review.user.name : 'N/A'
                    td
                      .review-rating
                        each n of [1,2,3,4,5]
                          if n <= review.rating
                            svg.review-rating__star
                              use(xlink:href='/img/icons.svg#icon-star')
                    td= review.review.substring(0, 50) + (review.review.length > 50 ? '...' : '')
                    td= new Date(review.createdAt).toLocaleDateString()
                    td
                      button.btn-admin-delete(data-review-id=review._id) Delete
